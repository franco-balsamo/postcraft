# ─── Database ────────────────────────────────────────────────────────────────
# Strong random password — generate with: openssl rand -hex 32
POSTGRES_PASSWORD=

# ─── Redis ───────────────────────────────────────────────────────────────────
# Strong random password — generate with: openssl rand -hex 32
REDIS_PASSWORD=

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Strong random secret — generate with: openssl rand -hex 64
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ─── Meta / Facebook OAuth ───────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_CALLBACK_URL=https://yourdomain.com/auth/meta/callback

# ─── Cloudinary ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=

# ─── URLs ────────────────────────────────────────────────────────────────────
APP_URL=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com
# Comma-separated list of allowed CORS origins (no wildcards)
CORS_ORIGIN=https://yourdomain.com
